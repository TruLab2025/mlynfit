ErrorDocument 404 /404.html
Options -Indexes

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"

  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>

  <FilesMatch "\.(json)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>

  <FilesMatch "\.(css|js|png|jpg|jpeg|webp|svg|ico|webmanifest)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^grafik-zajec/?$ /terminarz/ [R=301,L]
  RewriteRule ^137-2/?$ /regulamin/ [R=301,L]
</IfModule>
